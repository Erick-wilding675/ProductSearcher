# ProductSearcher — api: variáveis de ambiente.
# Copie para `.env` e preencha. NÃO commite o `.env` (só este .example).
#   cp .env.example .env

# Conexão do Postgres/Supabase usada pelo Alembic (migrations) e pela API.
# IMPORTANTE: para MIGRATIONS e a CARGA do seed use o POOLER DE SESSÃO (porta 5432),
# não o de transação (6543) — o pooler de transação quebra DDL e prepared statements.
# Deixe a 6543 para o runtime da API depois.
DATABASE_URL=postgresql+psycopg://postgres.<ref>:<senha>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# CORS — clientes que podem chamar a API (ver app/core/config.py).
# Web app: origens explícitas separadas por vírgula (dev e, depois, prod).
CORS_ORIGINS=["http://localhost:3000"]
# Extensão de browser: regex das origens de extensão (id não é fixo em dev).
CORS_ORIGIN_REGEX=^(chrome-extension|moz-extension)://[a-z0-9]+$
