# Copie para .env: `cp .env.example .env`. NÃO commitar segredos (.env é ignorado).
#
# Para desenvolver você NÃO precisa do Supabase. Há dois cenários:
#
#  A) Docker (recomendado): `make up` / `docker compose up` já injeta as variáveis
#     do compose — você nem precisa de .env. Use este arquivo só se rodar fora do Docker.
#
#  B) Backend no venv local (sem Docker), conectando no Postgres do compose:
#     troque o host `db` por `localhost` na DATABASE_URL abaixo.

# --- Banco (DEV) ---
# Padrão = Postgres local do docker compose (rede interna, host `db`).
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/productsearcher
# Rodando no venv local (fora do Docker), use:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/productsearcher

# --- Banco (PRODUÇÃO) ---
# Supabase é só produção. NÃO coloque a string com senha real aqui (arquivo versionado):
# defina DATABASE_URL nas secrets do host de deploy. Formato (Transaction pooler):
# DATABASE_URL=postgresql+psycopg://postgres.fzbaamyeyffnprinrkva:SENHA@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# IA é complementar — desligada por padrão (princípio do projeto)
AI_ENABLED=false
# OPENAI_API_KEY=        # opcional, só se AI_ENABLED=true (Fase 6)

# CORS (origens dos clientes)
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
