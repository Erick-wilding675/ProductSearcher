# ProductSearcher — worker: variáveis de ambiente.
# Copie para `.env` e preencha. NÃO commite o `.env` (só este .example).
#   cp .env.example .env

# --- Mercado Livre (seed-builder offline) ---
# Credenciais do app dev: https://developers.mercadolivre.com.br → suas aplicações.
ML_CLIENT_ID=            # "ID do aplicativo"
ML_CLIENT_SECRET=        # "Chave secreta" (rotacione se vazar)

# OAuth. localhost NÃO é aceito como redirect; use um https público válido.
ML_REDIRECT_URI=         # ex.: https://productsearcher.vercel.app/callback

# Gerados em runtime pelo tools.seedbuilder.ml_auth:
ML_REFRESH_TOKEN=        # após o 1º "exchange"; usado pelo "refresh"
ML_ACCESS_TOKEN=         # token atual (~6h); consumido pelo build_seed

# --- Banco (pipeline de ingestão) ---
DATABASE_URL=            # postgresql://...  (Supabase pooler, porta 6543)
